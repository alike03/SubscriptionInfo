{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"compilerOptions": {
		"target": "ESNext",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"moduleResolution": "Node",
		"strict": true,
		"allowJs": false,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"baseUrl": ".",
		"paths": {
			"$lib/*": [
				"./src/page/lib/*"
			]
		},
		"lib": [
			"ESNext",
			"DOM"
		],
		"skipLibCheck": true,
		"types": [
			"webextension-polyfill"
		],
		"noEmit": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte"
	],
	"references": [
		{
			"path": "./tsconfig.node.json"
		}
	]
}